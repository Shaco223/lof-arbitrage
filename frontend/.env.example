# 联调时复制为 .env.development / .env.production，并按 dev-004 给的 uniCloud URL 填写
# - VITE_API_BASE：uniCloud URL 化云函数前缀（例如 https://xxx.next.bspapp.com）
# - VITE_USE_MOCK：true / false。开关到 false 后调真实接口；本地 mock 兜底默认 true
# - VITE_POLL_INTERVAL_MS：Dashboard 列表轮询间隔（PRD §4.2 默认 60000）
VITE_API_BASE=
VITE_USE_MOCK=true
VITE_POLL_INTERVAL_MS=60000

# 可选：本机 dev 时把 /api 反向代理到某个服务器（例如 http://14.103.92.32）
# - 仅 .env.development 使用；.env.production 忽略此项
# - 需要同时设置 VITE_API_BASE=/api 才能触发代理
VITE_DEV_PROXY_TARGET=


# Cloud function name mapping. Defaults follow current dev-004 uniCloud function directories: lof-*; response payload still follows PRD section 6.
# If cloud function names change, update only these values; do not change page code or PRD section 6 fields.
VITE_API_FN_LIST=lof-list
VITE_API_FN_DETAIL=lof-detail
VITE_API_FN_HISTORY=lof-history
VITE_API_FN_INGEST=lof-ingest
