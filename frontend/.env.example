# 联调时复制为 .env.development / .env.production，并按 dev-004 给的 uniCloud URL 填写
# - VITE_API_BASE：uniCloud URL 化云函数前缀（例如 https://xxx.next.bspapp.com）
# - VITE_USE_MOCK：true / false。开关到 false 后调真实接口；本地 mock 兜底默认 true
# - VITE_POLL_INTERVAL_MS：Dashboard 列表轮询间隔（PRD §4.2 默认 60000）
VITE_API_BASE=
VITE_USE_MOCK=true
VITE_POLL_INTERVAL_MS=60000


# Cloud function name mapping. Defaults follow PRD section 6: api-lof-* / ingest-realtime.
# If dev-004 deploys as lof-list / lof-detail / lof-history / lof-ingest, change only these values.
VITE_API_FN_LIST=api-lof-list
VITE_API_FN_DETAIL=api-lof-detail
VITE_API_FN_HISTORY=api-lof-history
VITE_API_FN_INGEST=ingest-realtime
